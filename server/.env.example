# MongoDB connection string (from Atlas → Connect → Compass format)
MONGODB_URI=mongodb://USER:PASSWORD@shard-00-00.xxxxx.mongodb.net:27017,.../?replicaSet=...&ssl=true&authSource=admin

# Server port (Render sets this automatically)
PORT=5000

# Frontend origin — set to your Vercel production URL after deploying
# Comma-separate multiple origins if needed:
# ALLOWED_ORIGIN=https://steelmove.vercel.app,https://www.steelmove.in
ALLOWED_ORIGIN=http://localhost:5173

# Node environment
NODE_ENV=development
